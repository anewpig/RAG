OPENAI_API_KEY=
EMBEDDING_PROVIDER=local
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
LOCAL_EMBEDDING_MODEL_NAME=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
CHAT_MODEL=gpt-4.1-mini

CHROMA_PERSIST_DIR=./chroma_db
CHROMA_COLLECTION_NAME=policylens_chunks

DATA_DIR=./data
APP_ENV=dev

CHUNK_SIZE=400
CHUNK_OVERLAP=60
EMBEDDING_BATCH_SIZE=64

RETRIEVAL_TOP_K=5
GENERATION_MAX_CHUNKS=4
GENERATION_MAX_OUTPUT_TOKENS=500
RETRIEVAL_MAX_DISTANCE=1.2
RETRIEVAL_MIN_RESULTS=1
CITATION_QUOTE_MAX_CHARS=180